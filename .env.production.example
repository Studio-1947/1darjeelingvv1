# Copy this to `.env` in the repo root on the VPS (NOT committed — already
# gitignored). Used by docker-compose.prod.yml for the postgres and backend
# services. TLS is handled by the VPS's system Nginx + Certbot, not by
# anything in this file — see README's "Production deployment" section.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=one_darjeeling
# DATABASE_URL is computed automatically by docker-compose.prod.yml from the
# three vars above (postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@postgres:5432/$POSTGRES_DB)
# — you don't need to set it here.

# --- Backend ---
PORT=8000
JWT_SECRET=change_me_to_a_long_random_secret
MOCK_PAYMENTS=false
APP_ENV=production
# Comma-separated list of allowed origins. Same-origin requests (browser
# calling /api on the same domain that served the page) never need CORS at
# all, so this only matters for any external caller hitting the API directly.
CORS_ORIGINS=https://onedarjeeling.duckdns.org

# --- Razorpay (required when MOCK_PAYMENTS=false) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Admin ---
# One-time secret required by POST /api/admin/bootstrap to create the first
# DB-backed admin. Generate a random value and use it once, then it's safe
# to leave in place (bootstrap refuses once any admin exists).
ADMIN_BOOTSTRAP_SECRET=change_me_to_a_long_random_secret
# Hardcoded admin login (POST /api/auth/admin/login). Change the password
# from this placeholder before going live.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
