# Copy this to `.env` in the repo root on the VPS (NOT committed — already
# gitignored). Used by docker-compose.prod.yml for the postgres and backend
# services. TLS is handled by the VPS's system Nginx + Certbot, not by
# anything in this file — see README's "Production deployment" section.
#
# Every change_me_* placeholder below MUST be replaced. The backend validates
# its config at startup and refuses to boot with APP_ENV=production if any
# secret is unset, left at a development default, or still a change_me_*
# placeholder — so a forgotten value fails the deploy loudly instead of
# silently shipping a publicly-known secret.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=one_darjeeling
# DATABASE_URL is computed automatically by docker-compose.prod.yml from the
# three vars above (postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@postgres:5432/$POSTGRES_DB)
# — you don't need to set it here.

# --- Backend ---
PORT=8000
JWT_SECRET=change_me_to_a_long_random_secret
APP_ENV=production
# Start with mocked payments so the site can go live before Razorpay is ready; checkout completes
# instantly and no money moves. Flip to false only once the three Razorpay values below are filled
# in — the backend refuses to start with MOCK_PAYMENTS=false and any of them missing, rather than
# failing at checkout in front of a paying customer.
MOCK_PAYMENTS=true
# Comma-separated list of allowed origins. Same-origin requests (browser
# calling /api on the same domain that served the page) never need CORS at
# all, so this only matters for any external caller hitting the API directly.
CORS_ORIGINS=https://onedarjeeling.duckdns.org

# --- Razorpay (all three required when MOCK_PAYMENTS=false) ---
# See README → "Razorpay setup" for where each of these comes from.
# Dashboard → Account & Settings → API Keys. Must be rzp_live_* when APP_ENV=production;
# an rzp_test_* key is rejected at startup so test keys can't quietly reach real customers.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Settings → Webhooks → the "Secret" field you set when creating the webhook.
# A DIFFERENT value from RAZORPAY_KEY_SECRET above. Without it the app cannot verify webhook
# deliveries, and payments where the customer closed the tab are charged but never settled.
RAZORPAY_WEBHOOK_SECRET=

# --- Admin ---
# One-time secret required by POST /api/admin/bootstrap to create the first
# DB-backed admin. Generate a random value and use it once, then it's safe
# to leave in place (bootstrap refuses once any admin exists).
ADMIN_BOOTSTRAP_SECRET=change_me_to_a_long_random_secret
# Hardcoded admin login (POST /api/auth/admin/login). Change the password
# from this placeholder before going live.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password

# --- Messaging / OTP delivery ---
# `mock` means OTPs are NOT delivered and the 123456 universal code is accepted, so anyone
# can log in as any phone number. That is intentional for a pre-launch staging deployment and
# the server logs a loud error about it at startup — but it must not be left this way once
# real users exist. Set a real provider and supply its credentials below.
MESSAGING_PROVIDER=mock

# Required when MESSAGING_PROVIDER=msg91 (startup fails without them).
# Dashboard -> API -> Auth Key, and the approved OTP template's ID.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
