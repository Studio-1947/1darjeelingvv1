# PostgreSQL connection string (required — server throws on startup without it)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/one_darjeeling

# Port the Express server listens on (default 8000 if unset)
PORT=8000

# Secret used to sign JWTs — set a real random value outside local dev
JWT_SECRET=your_jwt_secret_here

# When true, payments are simulated (no real Razorpay call) via /api/payments/mock/complete
MOCK_PAYMENTS=true

# 'development' or 'production'. Controls mock-OTP responses, HSTS header, etc.
APP_ENV=development

# Comma-separated allowed origins, or * for any (dev only — do not use * in production)
CORS_ORIGINS=*

# Razorpay live/test keys — required when MOCK_PAYMENTS=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# One-time secret required by POST /api/admin/bootstrap to create the first DB-backed admin
ADMIN_BOOTSTRAP_SECRET=

# Hardcoded admin login credentials (POST /api/auth/admin/login) — change before any shared deployment
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword123
