# PostgreSQL connection string (required — server throws on startup without it)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/one_darjeeling

# Port the Express server listens on (default 8000 if unset)
PORT=8000

# Secret used to sign JWTs. Optional in development (falls back to a known insecure
# dev value); REQUIRED when APP_ENV=production — the server refuses to start there if
# it's unset, left at the dev default, or still a change_me_* placeholder.
JWT_SECRET=your_jwt_secret_here

# When true, payments are simulated (no real Razorpay call) via /api/payments/mock/complete
MOCK_PAYMENTS=true

# REQUIRED — one of: development | test | production. Not defaulted: the server refuses
# to start if this is unset, because guessing "development" in production would silently
# enable the mock-OTP bypass and the insecure dev secret defaults.
APP_ENV=development

# Comma-separated allowed origins, or * for any (dev only — rejected at startup when
# APP_ENV=production)
CORS_ORIGINS=*

# Razorpay keys — all three REQUIRED when MOCK_PAYMENTS=false (startup fails without them).
# Dashboard → Account & Settings → API Keys. Test keys look like rzp_test_*; live keys rzp_live_*.
# A test key with APP_ENV=production is rejected at startup.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard → Settings → Webhooks → the "Secret" you choose when creating the webhook.
# This is NOT the same value as RAZORPAY_KEY_SECRET. Used only to verify the
# X-Razorpay-Signature header on POST /api/payments/webhook. Without it, any payment where
# the customer closes the tab before the callback fires is charged but never settled.
RAZORPAY_WEBHOOK_SECRET=

# One-time secret required by POST /api/admin/bootstrap to create the first DB-backed
# admin. May be empty in development; REQUIRED when APP_ENV=production.
ADMIN_BOOTSTRAP_SECRET=

# Hardcoded admin login credentials (POST /api/auth/admin/login). The password below is
# the development default and is REJECTED at startup when APP_ENV=production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword123

# --- Messaging / OTP delivery ---
# Which provider delivers login OTPs. `mock` delivers nothing and returns the code in the
# API response, which is what makes local development work with no accounts set up.
# Registered values: mock, msg91
MESSAGING_PROVIDER=mock

# Required when MESSAGING_PROVIDER=msg91. The server refuses to start without them.
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# How long an issued OTP stays valid, and how many wrong guesses it tolerates before the
# caller must request a new one. Both optional; defaults shown.
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
